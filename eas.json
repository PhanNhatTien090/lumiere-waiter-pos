{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://lumiere-restaurant-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://lumiere-restaurant-backend.onrender.com/ws"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://lumiere-restaurant-backend.onrender.com/api/v1",
        "EXPO_PUBLIC_WS_URL": "https://lumiere-restaurant-backend.onrender.com/ws"
      }
    }
  }
}
